global:
  scrape_interval: 15s  # How often to scrape targets by default
  evaluation_interval: 15s  # How often to evaluate rules

scrape_configs:
  - job_name: 'mysql'
    static_configs:
      - targets: ['db.devops.ikocs.net:9104']
  
  - job_name: 'node'
    static_configs:
      - targets: ['db.devops.ikocs.net:9100']